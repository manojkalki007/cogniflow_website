# Cogniflow Environment Variables — Reference
# Copy to .env.local and fill in values. Never commit .env.local.

# === Backend ===
BACKEND_URL=
NEXT_PUBLIC_BACKEND_URL=

# === Supabase ===
# Get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=

# === Auth ===
ADMIN_EMAILS=admin@yourdomain.com

# === Cal.com ===
NEXT_PUBLIC_CAL_LINK=yourusername/30min
CAL_WEBHOOK_SECRET=

# === Razorpay ===
# Test keys: rzp_test_*  Production keys: rzp_live_*
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_GROWTH=
RAZORPAY_WEBHOOK_SECRET=

# === Voice Providers (backend) ===
DEEPGRAM_API_KEY=
GROQ_API_KEY=
SARVAM_API_KEY=
SMALLEST_AI_API_KEY=
ELEVENLABS_API_KEY=

# === Telephony (backend) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_ACCOUNT_SID=
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=

# === Monitoring ===
ALERT_WEBHOOK=

# === Server ===
API_SECRET_KEY=
WEBHOOK_SECRET=
PUBLIC_URL=https://your-domain.com
DEBUG=false
